"""Default entrypoint."""

import os
import sys
import traceback

from qiskit_serverless import get_arguments, save_result, send_error, ServerlessError

sys.path.append("{{mount_path}}")

from {{package_name}} import Runner

try:
    arguments = get_arguments()
except Exception:
    save_result(traceback.format_exc())
    raise

try:
    runner = Runner()
    result = runner.run(arguments)

    if result is not None:
        save_result(result)
except ServerlessError as e:
    error_type = type(e).__name__
    send_error(e.code, e.message, error_type, e.details)
    raise
except Exception as e:
    error_type = type(e).__name__
    send_error(1, traceback.format_exception_only(e), error_type)
    save_result(traceback.format_exception_only(e))
    raise
