{% autoescape off %}# Fleet wrapper for provider jobs — Python implementation.
#
# In Fleets the gateway cannot read logs in real time from the worker, so the
# wrapper that runs inside the container ships the logs to COS itself.  Output
# is written to two local /tmp files (fast disk) and periodically copied to
# the COS-backed mount.  A signal handler + try/finally guarantee a final flush
# so no buffered output is lost when the container terminates.
#
# Provider jobs split output into two logs:
#
#   $PUBLIC_LOG_PATH  (/logs, visible to the job author):
#     Only [PUBLIC]-tagged lines, with the prefix stripped.
#     Equivalent to filter_logs_with_public_tags in core.domain.filter_logs.
#
#   $PRIVATE_LOG_PATH (/provider-logs, visible to the provider):
#     [PRIVATE]-tagged lines (prefix stripped) + all untagged lines verbatim.
#     [PUBLIC] lines are excluded to protect provider IP.
#     Equivalent to filter_logs_with_non_public_tags in core.domain.filter_logs.
#
# Matching is case-insensitive to mirror the Python re.IGNORECASE used in
# core.domain.filter_logs.
import os, shutil, signal, subprocess, sys, threading

_INTERVAL  = int(os.environ.get('LOG_FLUSH_INTERVAL_SECONDS', 15))
_LIMIT     = int(os.environ.get('LOG_SIZE_LIMIT_BYTES', 52428800))
_DST_PUB   = os.environ['PUBLIC_LOG_PATH']
_DST_PRIV  = os.environ['PRIVATE_LOG_PATH']
_LOC_PUB   = '/tmp/public.log'
_LOC_PRIV  = '/tmp/private.log'

_stop = threading.Event()
_proc = None
_t    = None


def _size(path):
    try:
        return os.path.getsize(path)
    except OSError:
        return -1


# Copies src to dst, capping output at _LIMIT bytes and shrinking src in-place
# when the limit is exceeded — reading the tail only once for both operations.
#
# When within the limit a plain copy is used.  When over, the last _LIMIT bytes
# are saved to a variable, written to dst with a truncation header, then
# restored to src via truncate+seek+write so the inode is preserved and any
# open write fd (the line-reader loop) remains valid after truncation.
def _upload(src, dst, size=None):
    if size is None:
        size = _size(src)
    if size < 0:
        return
    if size > _LIMIT:
        mb  = _LIMIT // 1048576
        hdr = (
            '[Logs exceeded maximum allowed size ({} MB). Logs have been '
            'truncated, discarding the oldest entries first.]\n'
        ).format(mb).encode()
        try:
            with open(src, 'rb') as f:
                f.seek(-_LIMIT, 2)
                tail = f.read()
            with open(dst, 'wb') as f:
                f.write(hdr)
                f.write(tail)
            with open(src, 'r+b') as f:
                f.truncate(0)
                f.seek(0)
                f.write(tail)
        except OSError:
            pass
    else:
        try:
            shutil.copy(src, dst)
        except OSError:
            pass


# Periodically copies both local logs to COS, skipping no-op PUTs when the
# app is silent or no line has matched a given filter.  Runs as a daemon thread.
def _run_uploader():
    last_pub = last_priv = -1
    while not _stop.wait(_INTERVAL):
        cur = _size(_LOC_PUB)
        if cur != last_pub:
            _upload(_LOC_PUB, _DST_PUB, cur)
            last_pub = _size(_LOC_PUB)
        cur = _size(_LOC_PRIV)
        if cur != last_priv:
            _upload(_LOC_PRIV, _DST_PRIV, cur)
            last_priv = _size(_LOC_PRIV)


# Stops the uploader thread (waits for any in-progress upload to finish), then
# performs one final unconditional upload of both logs.
def _flush():
    _stop.set()
    if _t is not None:
        _t.join(timeout=5)
    _upload(_LOC_PUB,  _DST_PUB)
    _upload(_LOC_PRIV, _DST_PRIV)


def _on_signal(sig, _frame):
    if _proc is not None:
        _proc.terminate()
    _flush()
    sys.exit(128 + sig)


signal.signal(signal.SIGTERM, _on_signal)
signal.signal(signal.SIGINT, _on_signal)

_t = threading.Thread(target=_run_uploader, daemon=True)
_t.start()

_proc = subprocess.Popen(
    {{ app_cmd }},
    stdout=subprocess.PIPE,
    stderr=subprocess.STDOUT,
    text=True,
    encoding='utf-8',
    errors='replace',
    bufsize=1,
)
try:
    with open(_LOC_PUB,  'a', buffering=1) as _pub, \
         open(_LOC_PRIV, 'a', buffering=1) as _priv:
        for _line in _proc.stdout:
            _h8 = _line[:8].upper()
            _h9 = _line[:9].upper()
            if _h8 == '[PUBLIC]':
                _pub.write(_line[9:])
                _pub.flush()
            elif _h9 == '[PRIVATE]':
                _priv.write(_line[10:])
                _priv.flush()
            else:
                _priv.write(_line)
                _priv.flush()
    _code = _proc.wait()
finally:
    _flush()

sys.exit(_code)
{% endautoescape %}
