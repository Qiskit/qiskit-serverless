{% autoescape off %}# Fleet wrapper for provider jobs.
#
# In Fleets the gateway cannot read logs in real time from the worker, so the
# wrapper inside the container is responsible for shipping the logs to COS
# itself. To avoid hammering the COS-backed mount on every line, we write
# the application output to two local files in /tmp (fast disk) and
# periodically copy them to the mount. A trap guarantees a final flush on
# exit so no buffered tail is lost when the container terminates.
#
# Provider jobs are like custom jobs but with an extra private log on top
# of the public one. The application output is split into two pre-filtered
# files matching what the endpoints expect:
#
#   - $PUBLIC_LOG_PATH:  the file served by /logs to the job's author. Only
#                        lines with a leading [PUBLIC] tag, with the tag
#                        removed (= filter_logs_with_public_tags).
#   - $PRIVATE_LOG_PATH: the file served by /provider-logs to the provider.
#                        Every other line. Lines with a leading [PRIVATE]
#                        tag are stripped of the tag; everything else is
#                        kept verbatim (= filter_logs_with_non_public_tags).
#
# The matching is case-insensitive to mirror the Python re.IGNORECASE used in
# core.domain.filter_logs. The SDK (qiskit_serverless.utils.loggers) emits
# uppercase [PUBLIC] / [PRIVATE], but accepting any case prevents drift.

set -eu

# Upload period (seconds) between local -> COS copies. Defaults to 15s.
INTERVAL="${LOG_FLUSH_INTERVAL_SECONDS:-15}"

# Maximum bytes of log content uploaded to COS. Defaults to 50 MB.
LOG_SIZE_LIMIT_BYTES="${LOG_SIZE_LIMIT_BYTES:-52428800}"

# Local working files. Append-only, fast, never read by COS during the run.
LOCAL_PUBLIC="/tmp/public.log"
LOCAL_PRIVATE="/tmp/private.log"

# Named pipe that fans the app output to the splitter awk, plus a sidecar
# file used to recover the application's exit code (the app runs inside a
# pipeline, so $? would refer to awk, not the app).
PIPE="/tmp/app.pipe"
EXIT_CODE_FILE="/tmp/app.status"

mkfifo "$PIPE"

# Splits the app output into two pre-filtered files (served as-is by the endpoints):
#
#   PUBLIC_LOG_PATH  (/logs, visible to the job author):
#     Only [PUBLIC] lines, with the prefix stripped.
#     Equivalent to filter_logs_with_public_tags in core.domain.filter_logs.
#
#   PRIVATE_LOG_PATH  (/provider-logs, visible to the provider):
#     [PRIVATE] lines (prefix stripped) + all unprefixed lines (print(), 3rd-party).
#     [PUBLIC] lines are excluded to protect provider IP.
#     Equivalent to filter_logs_with_non_public_tags in core.domain.filter_logs.
#
# Sets LOGGER_PID so we can wait for the splitter to drain after the app exits.
start_log_splitter() {
  awk -v pub="$LOCAL_PUBLIC" -v priv="$LOCAL_PRIVATE" '{
    head8 = toupper(substr($0, 1, 8))
    head9 = toupper(substr($0, 1, 9))
    if (head8 == "[PUBLIC]") {
      print substr($0, 10) >> pub
      fflush(pub)
    } else if (head9 == "[PRIVATE]") {
      print substr($0, 11) >> priv
      fflush(priv)
    } else {
      print $0 >> priv
      fflush(priv)
    }
  }' < "$PIPE" &
  LOGGER_PID=$!
}
start_log_splitter

# Returns the file size in bytes via a single stat syscall (no file read).
file_size() {
  stat -c %s "$1" 2>/dev/null || echo -1
}

# Copies src to dst, capping output at LOG_SIZE_LIMIT_BYTES.
# When the source exceeds the limit the last LOG_SIZE_LIMIT_BYTES bytes are
# kept and a header line is prepended, mirroring check_logs in core.utils.
# Optional third argument: already-known source size, to avoid a second stat.
upload_log() {
  local src="$1" dst="$2"
  local size="${3:-$(file_size "$src")}"
  [ "$size" -lt 0 ] && return 0
  if [ "$size" -gt "$LOG_SIZE_LIMIT_BYTES" ]; then
    local mb=$(( LOG_SIZE_LIMIT_BYTES / 1048576 ))
    { printf '[Logs exceeded maximum allowed size (%s MB). Logs have been truncated, discarding the oldest entries first.]\n' "$mb"
      tail -c "$LOG_SIZE_LIMIT_BYTES" "$src"
    } > "$dst" 2>/dev/null
  else
    cp "$src" "$dst" 2>/dev/null
  fi
}

# Shrinks a local log file in-place to the last LOG_SIZE_LIMIT_BYTES bytes,
# keeping the same inode so any open write fd (awk) remains valid.
#
# Mechanism: `truncate -s 0` zeros the file without changing the inode; awk's
# next O_APPEND write lands at offset 0. Then `cat >>` restores the saved tail.
# The brief race window between the two operations is harmless: a few lines
# written by awk may appear before the restored tail in the file, which is
# acceptable for a log. This keeps /tmp bounded to ~2x LOG_SIZE_LIMIT_BYTES.
truncate_local() {
  local file="$1"
  local size
  size=$(file_size "$file")
  [ "$size" -le "$LOG_SIZE_LIMIT_BYTES" ] && return 0
  local tmp="${file}.shrink"
  tail -c "$LOG_SIZE_LIMIT_BYTES" "$file" > "$tmp" 2>/dev/null || { rm -f "$tmp"; return 0; }
  truncate -s 0 "$file" 2>/dev/null || { rm -f "$tmp"; return 0; }
  cat "$tmp" >> "$file" 2>/dev/null || true
  rm -f "$tmp"
}

# Periodically copies both local logs to COS, skipping no-op PUTs when the
# app is silent or no line has matched the public filter.
# Sets UPLOADER_PID so flush_final can stop it on exit.
start_uploader() {
  (
    last_public_log_size=-1
    last_private_log_size=-1
    while :; do
      sleep "$INTERVAL"
      cur=$(file_size "$LOCAL_PUBLIC")
      if [ "$cur" != "$last_public_log_size" ]; then
        # New public lines since last upload — push to COS, then shrink local.
        if upload_log "$LOCAL_PUBLIC" "$PUBLIC_LOG_PATH" "$cur"; then
          truncate_local "$LOCAL_PUBLIC"
          last_public_log_size=$(file_size "$LOCAL_PUBLIC")
        fi
      fi
      cur=$(file_size "$LOCAL_PRIVATE")
      if [ "$cur" != "$last_private_log_size" ]; then
        # New private lines since last upload — push to COS, then shrink local.
        if upload_log "$LOCAL_PRIVATE" "$PRIVATE_LOG_PATH" "$cur"; then
          truncate_local "$LOCAL_PRIVATE"
          last_private_log_size=$(file_size "$LOCAL_PRIVATE")
        fi
      fi
    done
  ) &
  UPLOADER_PID=$!
}
start_uploader

# On exit (normal, SIGTERM, SIGINT) stop the uploader and force one final
# unconditional copy of both logs, so COS reflects the very last lines.
flush_final() {
  kill "$UPLOADER_PID" 2>/dev/null || true
  upload_log "$LOCAL_PUBLIC" "$PUBLIC_LOG_PATH" || true
  upload_log "$LOCAL_PRIVATE" "$PRIVATE_LOG_PATH" || true
}
trap 'flush_final' EXIT TERM INT

# Runs the app and records its exit code to $EXIT_CODE_FILE.
# Must run in a subshell so set +e does not leak to the outer script.
run_app() {
  set +e
  {{ app_cmd }}
  printf "%s\n" "$?" > "$EXIT_CODE_FILE"
}

( run_app ) > "$PIPE" 2>&1

# Wait for the splitter to drain the remaining buffered lines.
# A failure here must not mask the application's exit code.
wait "$LOGGER_PID" || true

# Validate that we actually captured an exit code; if not, fail loudly so
# the wrapper does not silently report success on a broken run.
if [ ! -f "$EXIT_CODE_FILE" ]; then
  echo "logging wrapper error: status file was not created" >&2
  exit 1
fi
STATUS="$(cat "$EXIT_CODE_FILE")"
case "$STATUS" in
  ""|*[!0-9]*) echo "logging wrapper error: invalid status: $STATUS" >&2; exit 1 ;;
esac

# Propagate the application's real exit code; the EXIT trap fires now and
# performs the final flush before the script terminates.
exit "$STATUS"
{% endautoescape %}
